rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Semua akses data dilakukan via Admin SDK di server (API routes)
    // Client SDK hanya dipakai untuk auth state, tidak untuk baca/tulis data
    // Maka semua collection di-lock dari client

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
